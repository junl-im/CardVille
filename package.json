    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "firebase": "12.15.0",
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "2.1.0",
    "typescript": "5.8.3",
    "vite": "6.3.5"
  }
}
