{
  "name": "cardville",
  "version": "0.3.0",
  "private": true,
  "description": "CardVille - Aqua Glass premium 2.5D card puzzle and collection game built with Phaser 3, TypeScript, Vite and Firebase.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
