{
  "name": "cardville",
  "version": "1.0.0-rc.2",
  "private": true,
  "description": "CardVille v1.0-rc.2 - boot stability, service worker cache recovery, runtime diagnostics and safer first-screen startup.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "check:imports": "node tools/check-relative-imports.mjs",
    "check:json": "node tools/check-json-data.mjs",
    "verify": "npm run check:boot && npm run check:imports && npm run check:json && npm run check:assets && npm run check:catalog && npm run check:ui && npm run build && npm run check:budget",
    "check:assets": "node tools/check-assets-policy.mjs",
    "check:budget": "node tools/check-bundle-budget.mjs",
    "check:catalog": "node tools/check-asset-catalog.mjs",
    "check:ui": "node tools/check-ui-layout.mjs",
    "check:boot": "node tools/check-boot-files.mjs"
  },
  "dependencies": {
    "firebase": "12.15.0",
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "2.1.0",
    "typescript": "5.8.3",
    "vite": "6.3.5"
  }
}
